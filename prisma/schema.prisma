generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  password        String
  balance         Float         @default(0)
  investBalance   Float         @default(0)
  tradeBalance    Float         @default(0)
  projectBalance  Float         @default(0)
  hasInvested     Boolean       @default(false)
  role            String        @default("user")
  emailVerified   Boolean       @default(false)
  depositCount    Int           @default(0)
  firstDepositAt  DateTime?
  lastClaimAt     DateTime?
  referralCode    String        @unique
  referredByCode  String?
  referralCount   Int           @default(0)
  totalProfit     Float         @default(0)
  totalLoss       Float         @default(0)
  transactions    Transaction[]
  investments     Investment[]
  trades          Trade[]
  enterprises     Enterprise[]
  chatMessages    ChatMessage[]
  pendingDeposits PendingDeposit[]
  passwordResetTokens PasswordResetToken[]
  withdrawals     Withdrawal[]
  yasDeposits     YasDeposit[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  type      String
  amount    Float
  detail    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Investment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level       Int
  amount      Float
  rate        Float
  totalCycles Int
  doneCycles  Int       @default(0)
  earned      Float     @default(0)
  status      String    @default("active")
  lastClaimAt DateTime?
  nextClaimAt DateTime?
  finishesAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Trade {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  direction   String
  durationSec Int
  asset       String   @default("BTC")
  result      String?
  profit      Float?
  entryPrice  Float    @default(0)
  exitPrice   Float?
  endsAt      DateTime
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enterprise {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String
  amount       Float
  durationDays Int
  daysElapsed  Int      @default(0)
  minReturn    Float
  maxReturn    Float
  finalReturn  Float?
  status       String   @default("active")
  riskEvents   String?
  finishesAt   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PendingDeposit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountUsd   Float
  amountTrx   Float
  trxPrice    Float
  userAddress String
  txHash      String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteConfig {
  id              String   @id @default("main")
  adminTrxAddress String   @default("")
  adminYasAccount String   @default("")
  trxUsdPrice     Float    @default(0.12)
  cfaUsdRate      Float    @default(600)
  updatedAt       DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  amountCfa   Float    @default(0)
  type        String   @default("trx")
  trxAddress  String?
  yasAccount  String?
  status      String   @default("pending")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  purpose   String   @default("login")
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model YasDeposit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCfa     Float    @default(0)
  amountUsd     Float
  amountTrx     Float
  trxPrice      Float
  yasAccount    String
  trxAddress    String?
  status        String   @default("pending")
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
